{
  "name": "workmatchr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:db": "npm run test:db:core && npm run test:db:providers && npm run test:db:accounts && npm run test:db:account-lifecycle && npm run test:db:marketplace && npm run test:db:marketplace-concurrency",
    "test:db:core": "tsx scripts/test-intake-database.ts",
    "test:db:providers": "tsx scripts/test-provider-dataset-database.ts",
    "test:db:accounts": "tsx scripts/test-account-architecture-database.ts",
    "test:db:account-lifecycle": "tsx scripts/test-account-lifecycle-database.ts",
    "test:db:marketplace": "tsx scripts/test-marketplace-database.ts",
    "test:db:marketplace-concurrency": "tsx scripts/test-marketplace-concurrency-database.ts",
    "db:generate": "prisma generate",
    "db:format": "prisma format",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "seed:test-providers": "tsx scripts/seed-test-providers.ts seed",
    "seed:test-providers:verify": "tsx scripts/seed-test-providers.ts verify",
    "seed:test-providers:remove": "tsx scripts/seed-test-providers.ts remove",
    "preflight:account-architecture": "tsx scripts/run-account-architecture-preflight.ts",
    "bootstrap:platform-organization": "tsx scripts/bootstrap-platform-organization.ts",
    "migrate:adr013-platform-provisioning": "tsx scripts/migrate-adr013-platform-provisioning.ts"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.23",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.0.0",
    "next": "^16.2.0",
    "pg": "^8.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.17.2",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10"
  }
}
