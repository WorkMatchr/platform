model CreditTransaction {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creditAccountId String                @db.Uuid
  type            CreditTransactionType
  amount          Int
  balanceAfter    Int
  referenceType   String?
  referenceId     String?               @db.Uuid
