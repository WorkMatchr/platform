generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  USER
  ADMIN
}

enum UserStatus {
  INVITED
  ACTIVE
  BLOCKED
  ARCHIVED
}

enum OrganizationType {
  CLIENT
  PROVIDER
  BOTH
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum OrganizationMembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum ProviderApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum CertificationVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ProviderLifecycleStatus {
  DRAFT
  READY_FOR_REVIEW
  IN_REVIEW
  CHANGES_REQUESTED
  QUALIFIED
  SUSPENDED
  REJECTED
  ARCHIVED
}

enum ProviderReadinessStatus {
  INCOMPLETE
  READY
  STALE
}

enum ProviderPlatformQualificationStatus {
  NOT_ASSESSED
  PENDING
  QUALIFIED
  CHANGES_REQUESTED
  REJECTED
  SUSPENDED
  EXPIRED
}

enum ProviderSelectabilityStatus {
  NOT_SELECTABLE
  SELECTABLE
  STALE
  BLOCKED
}

enum ProviderVerificationLevel {
  SELF_DECLARED
  DOCUMENT_CHECKED
  VERIFIED
}

enum ProviderCapacityLevel {
  LIMITED
  NORMAL
  AMPLE
}

enum ProviderDeliveryMode {
  ON_SITE
  HYBRID
  REMOTE
}

enum ProviderTaxonomyKind {
  SERVICE
  SPECIALISM
  SECTOR
  COMPETENCY
  QUALIFICATION
  CERTIFICATION
  REGION
  INSURANCE_TYPE
}

enum ProviderTaxonomyVersionStatus {
  DRAFT
  PUBLISHED
  RETIRED
}

enum ProviderRecordStatus {
  ACTIVE
  ARCHIVED
}

enum ProviderPlatformPermission {
  PROVIDER_REVIEWER
  PROVIDER_APPROVER
  PROVIDER_AUDITOR
}

enum ProviderQualificationScope {
  PLATFORM
  CAPABILITY
}

enum ProviderQualificationOutcome {
  QUALIFIED
  CHANGES_REQUESTED
  REJECTED
  SUSPENDED
  RESTORED
  EXPIRED
}

enum ProviderVerificationOutcome {
  DOCUMENT_CHECKED
  VERIFIED
  CHANGES_REQUESTED
  REJECTED
  EXPIRED
}

enum ProviderBlockType {
  COMPLIANCE
  QUALIFICATION
  SECURITY
  LEGAL
  DATA_QUALITY
}

enum ProviderEvidenceStatus {
  DRAFT
  AVAILABLE
  ARCHIVED
}

enum ProviderEvidenceScanStatus {
  PENDING
  CLEAN
  QUARANTINED
  REJECTED
}

enum ProviderTermStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum ProviderRequirementKind {
  QUALIFICATION
  CERTIFICATION
}

enum IntakeStatus {
  DRAFT
  IN_PROGRESS
  READY_FOR_REVIEW
  SUBMITTED
  CONVERTED
  ARCHIVED
}

enum IntakeQuestionnaireVersionStatus {
  DRAFT
  PUBLISHED
  RETIRED
}

enum IntakeQuestionCategory {
  HELP_REQUEST
  DESIRED_OUTCOME
  SITUATION
  IMPACT
  URGENCY
  LOCATION
  WORK_MODE
  PLANNING
  CONSTRAINTS
}

enum IntakeQuestionInputType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  BOOLEAN
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  ORGANIZATION_LOCATION
}

enum AssignmentStatus {
  DRAFT
  READY_FOR_REVIEW
  OPEN
  MATCHING
  AWAITING_RESPONSES
  IN_SELECTION
  AWARDED
  CLOSED
  CANCELLED
  ARCHIVED
}

enum ProviderSelectionSource {
  AUTOMATIC
  MANUAL_ADMIN
  CLIENT_REQUEST
}

enum ProviderSelectionStatus {
  SELECTED
  INVITED
  VIEWED
  RESPONDED
  DECLINED
  REMOVED
  AWARDED
}

enum AssignmentResolutionType {
  PROVIDER_AWARDED
  EXTERNAL_REFERRAL
  SELF_HANDLED
}

enum CreditTransactionType {
  PURCHASE
  SPEND
  REFUND
  ADMIN_ADJUSTMENT
  EXPIRATION
}

model User {
  id                               String                                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                            String                                 @unique
  displayName                      String?
  emailVerified                    Boolean                                @default(false)
  image                            String?
  platformRole                     PlatformRole                           @default(USER)
  status                           UserStatus                             @default(INVITED)
  createdAt                        DateTime                               @default(now()) @db.Timestamptz(3)
  updatedAt                        DateTime                               @updatedAt @db.Timestamptz(3)
  archivedAt                       DateTime?                              @db.Timestamptz(3)
  memberships                      OrganizationMembership[]
  approvedProviderProfiles         ProviderProfile[]                      @relation("ProviderProfileApprover")
  verifiedProviderCertificates     ProviderCertification[]                @relation("CertificationVerifier")
  createdIntakes                   Intake[]                               @relation("IntakeCreator")
  submittedIntakes                 Intake[]                               @relation("IntakeSubmitter")
  updatedIntakeAnswers             IntakeAnswer[]                         @relation("IntakeAnswerUpdater")
  changedIntakeAnswerRevisions     IntakeAnswerRevision[]                 @relation("IntakeAnswerRevisionActor")
  changedIntakeStatuses            IntakeStatusHistory[]                  @relation("IntakeStatusHistoryActor")
  createdAssignments               Assignment[]                           @relation("AssignmentCreator")
  publishedAssignments             Assignment[]                           @relation("AssignmentPublisher")
  changedAssignmentStatuses        AssignmentStatusHistory[]              @relation("AssignmentStatusHistoryActor")
  changedAssignmentRevisions       AssignmentRevision[]                   @relation("AssignmentRevisionActor")
  selectedProviderSelections       AssignmentProviderSelection[]          @relation("ProviderSelectionActor")
  assignmentResolutions            AssignmentResolution[]                 @relation("AssignmentResolutionActor")
  adminActions                     AdminActionLog[]                       @relation("AdminActionActor")
  createdCreditTransactions        CreditTransaction[]                    @relation("CreditTransactionActor")
  sessions                         Session[]
  accounts                         Account[]
  providerPermissionSubjects       ProviderPlatformPermissionGrant[]      @relation("ProviderPermissionSubject")
  providerPermissionGranters       ProviderPlatformPermissionGrant[]      @relation("ProviderPermissionGranter")
  providerPermissionRevokers       ProviderPlatformPermissionRevocation[] @relation("ProviderPermissionRevoker")
  providerTermAcceptances          ProviderTermAcceptance[]
  providerVerificationReviews      ProviderVerificationReview[]           @relation("ProviderVerificationReviewer")
  providerQualificationReviews     ProviderQualificationDecision[]        @relation("ProviderQualificationReviewer")
  providerQualificationApprovals   ProviderQualificationDecision[]        @relation("ProviderQualificationApprover")
  providerReadinessAssessments     ProviderReadinessAssessment[]
  providerSelectabilityAssessments ProviderSelectabilityAssessment[]
  providerBlocks                   ProviderBlock[]                        @relation("ProviderBlockActor")
  providerBlockReviews             ProviderBlock[]                        @relation("ProviderBlockReviewer")
  providerBlockReleases            ProviderBlockRelease[]                 @relation("ProviderBlockReleaseActor")
  providerBlockReleaseReviews      ProviderBlockRelease[]                 @relation("ProviderBlockReleaseReviewer")
  providerProjections              TrustedProviderProjection[]

  @@index([status])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime @db.Timestamptz(3)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @db.Uuid
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(3)
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(3)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  @@index([identifier])
  @@index([expiresAt])
}

model RateLimit {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String @unique
  count       Int
  lastRequest BigInt
}

model Organization {
  id                      String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  tradeName               String?
  chamberOfCommerceNumber String?
  organizationType        OrganizationType
  status                  OrganizationStatus          @default(PENDING)
  website                 String?
  phone                   String?
  generalEmail            String?
  employeeCount           Int?
  logoStorageKey          String?                     @unique
  logoMimeType            String?
  logoSizeBytes           Int?
  logoWidth               Int?
  logoHeight              Int?
  logoUpdatedAt           DateTime?                   @db.Timestamptz(3)
  createdAt               DateTime                    @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime                    @updatedAt @db.Timestamptz(3)
  archivedAt              DateTime?                   @db.Timestamptz(3)
  memberships             OrganizationMembership[]
  locations               OrganizationLocation[]
  sectors                 OrganizationSector[]
  providerProfile         ProviderProfile?
  clientIntakes           Intake[]
  clientAssignments       Assignment[]
  creditAccount           CreditAccount?
  insuredProviderPolicies ProviderInsuranceRevision[] @relation("InsuredOrganization")

  @@index([organizationType])
  @@index([status])
  @@index([createdAt])
}

model OrganizationMembership {
  id             String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String                     @db.Uuid
  organizationId String                     @db.Uuid
  role           OrganizationMembershipRole
  status         MembershipStatus           @default(INVITED)
  createdAt      DateTime                   @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime                   @updatedAt @db.Timestamptz(3)
  user           User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model OrganizationLocation {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                 @db.Uuid
  label               String
  addressLine         String
  postalCode          String
  city                String
  province            String?
  countryCode         String                 @db.Char(2)
  isPrimary           Boolean                @default(false)
  createdAt           DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime               @updatedAt @db.Timestamptz(3)
  archivedAt          DateTime?              @db.Timestamptz(3)
  organization        Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assignments         Assignment[]
  assignmentRevisions AssignmentRevision[]
  intakeAnswers       IntakeAnswer[]
  answerRevisions     IntakeAnswerRevision[]

  @@index([organizationId])
  @@index([city])
  @@index([archivedAt])
}

model Sector {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String
  slug                      String                     @unique
  description               String?
  isActive                  Boolean                    @default(true)
  createdAt                 DateTime                   @default(now()) @db.Timestamptz(3)
  updatedAt                 DateTime                   @updatedAt @db.Timestamptz(3)
  organizations             OrganizationSector[]
  providers                 ProviderSector[]
  assignments               Assignment[]
  assignmentRevisions       AssignmentRevision[]
  providerSectorTaxonomyMap ProviderSectorTaxonomyMap?

  @@index([isActive])
}

model OrganizationSector {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  sectorId       String       @db.Uuid
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sector         Sector       @relation(fields: [sectorId], references: [id], onDelete: Restrict)

  @@unique([organizationId, sectorId])
  @@index([organizationId])
  @@index([sectorId])
}

model Specialism {
  id                            String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String
  slug                          String                         @unique
  description                   String?
  parentId                      String?                        @db.Uuid
  isActive                      Boolean                        @default(true)
  createdAt                     DateTime                       @default(now()) @db.Timestamptz(3)
  updatedAt                     DateTime                       @updatedAt @db.Timestamptz(3)
  parent                        Specialism?                    @relation("SpecialismHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children                      Specialism[]                   @relation("SpecialismHierarchy")
  providers                     ProviderSpecialism[]
  detectedIntakes               Intake[]                       @relation("DetectedIntakeSpecialism")
  primaryAssignments            Assignment[]                   @relation("PrimaryAssignmentSpecialism")
  primaryAssignmentRevisions    AssignmentRevision[]           @relation("PrimaryAssignmentRevisionSpecialism")
  assignmentSpecialisms         AssignmentSpecialism[]
  providerSpecialismTaxonomyMap ProviderSpecialismTaxonomyMap?

  @@index([parentId])
  @@index([isActive])
}

model ProviderProfile {
  id                          String                              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId              String                              @unique @db.Uuid
  approvalStatus              ProviderApprovalStatus              @default(DRAFT)
  approvedAt                  DateTime?                           @db.Timestamptz(3)
  approvedByUserId            String?                             @db.Uuid
  rejectionReason             String?
  description                 String?
  maxTravelDistanceKm         Int?
  acceptsRemoteWork           Boolean                             @default(false)
  isAvailable                 Boolean                             @default(false)
  createdAt                   DateTime                            @default(now()) @db.Timestamptz(3)
  updatedAt                   DateTime                            @updatedAt @db.Timestamptz(3)
  archivedAt                  DateTime?                           @db.Timestamptz(3)
  lifecycleStatus             ProviderLifecycleStatus             @default(DRAFT)
  readinessStatus             ProviderReadinessStatus             @default(INCOMPLETE)
  platformQualificationStatus ProviderPlatformQualificationStatus @default(NOT_ASSESSED)
  selectabilityStatus         ProviderSelectabilityStatus         @default(NOT_SELECTABLE)
  version                     Int                                 @default(1)
  organization                Organization                        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  approvedByUser              User?                               @relation("ProviderProfileApprover", fields: [approvedByUserId], references: [id], onDelete: Restrict)
  specialisms                 ProviderSpecialism[]
  sectors                     ProviderSector[]
  certifications              ProviderCertification[]
  assignmentSelections        AssignmentProviderSelection[]
  assignmentResolutions       AssignmentResolution[]
  capabilities                ProviderCapability[]
  sectorExperiences           ProviderSectorExperience[]
  workAreas                   ProviderWorkArea[]
  capacitySnapshots           ProviderCapacitySnapshot[]
  professionals               ProviderProfessional[]
  organizationQualifications  ProviderOrganizationQualification[]
  insurances                  ProviderInsurance[]
  evidenceDocuments           ProviderEvidenceDocument[]
  termAcceptances             ProviderTermAcceptance[]
  verificationReviews         ProviderVerificationReview[]
  qualificationDecisions      ProviderQualificationDecision[]
  readinessAssessments        ProviderReadinessAssessment[]
  selectabilityAssessments    ProviderSelectabilityAssessment[]
  blocks                      ProviderBlock[]
  trustedProjections          TrustedProviderProjection[]
  migrationAudits             ProviderMigrationAudit[]

  @@index([approvalStatus])
  @@index([isAvailable])
  @@index([archivedAt])
  @@index([lifecycleStatus])
  @@index([readinessStatus])
  @@index([platformQualificationStatus])
  @@index([selectabilityStatus])
}

model ProviderSpecialism {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerProfileId String          @db.Uuid
  specialismId      String          @db.Uuid
  experienceYears   Int?
  isPrimary         Boolean         @default(false)
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  specialism        Specialism      @relation(fields: [specialismId], references: [id], onDelete: Restrict)

  @@unique([providerProfileId, specialismId])
  @@index([providerProfileId])
  @@index([specialismId])
}

model ProviderSector {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerProfileId String          @db.Uuid
  sectorId          String          @db.Uuid
  experienceYears   Int?
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  sector            Sector          @relation(fields: [sectorId], references: [id], onDelete: Restrict)

  @@unique([providerProfileId, sectorId])
  @@index([providerProfileId])
  @@index([sectorId])
}

model Certification {
  id                               String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                             String
  slug                             String                            @unique
  issuer                           String?
  description                      String?
  isActive                         Boolean                           @default(true)
  createdAt                        DateTime                          @default(now()) @db.Timestamptz(3)
  updatedAt                        DateTime                          @updatedAt @db.Timestamptz(3)
  providers                        ProviderCertification[]
  providerCertificationTaxonomyMap ProviderCertificationTaxonomyMap?

  @@index([isActive])
}

model ProviderCertification {
  id                 String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerProfileId  String                          @db.Uuid
  certificationId    String                          @db.Uuid
  certificateNumber  String?
  issuedAt           DateTime?                       @db.Date
  expiresAt          DateTime?                       @db.Date
  verificationStatus CertificationVerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?                       @db.Timestamptz(3)
  verifiedByUserId   String?                         @db.Uuid
  createdAt          DateTime                        @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime                        @updatedAt @db.Timestamptz(3)
  archivedAt         DateTime?                       @db.Timestamptz(3)
  providerProfile    ProviderProfile                 @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  certification      Certification                   @relation(fields: [certificationId], references: [id], onDelete: Restrict)
  verifiedByUser     User?                           @relation("CertificationVerifier", fields: [verifiedByUserId], references: [id], onDelete: Restrict)

  @@index([providerProfileId])
  @@index([certificationId])
  @@index([verificationStatus])
  @@index([expiresAt])
  @@index([archivedAt])
}

model ProviderTaxonomy {
  id        String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind      ProviderTaxonomyKind      @unique
  code      String                    @unique
  name      String
  createdAt DateTime                  @default(now()) @db.Timestamptz(3)
  versions  ProviderTaxonomyVersion[]
}

model ProviderReasonCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique
  domain    String
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([domain, isActive])
}

model ProviderTaxonomyVersion {
  id          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taxonomyId  String                        @db.Uuid
  version     Int
  status      ProviderTaxonomyVersionStatus @default(DRAFT)
  checksum    String?                       @db.VarChar(64)
  publishedAt DateTime?                     @db.Timestamptz(3)
  retiredAt   DateTime?                     @db.Timestamptz(3)
  createdAt   DateTime                      @default(now()) @db.Timestamptz(3)
  taxonomy    ProviderTaxonomy              @relation(fields: [taxonomyId], references: [id], onDelete: Restrict)
  terms       ProviderTaxonomyTerm[]

  @@unique([taxonomyId, version])
  @@index([status])
}

model ProviderTaxonomyTerm {
  id                                 String                                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  versionId                          String                                       @db.Uuid
  code                               String
  label                              String
  parentId                           String?                                      @db.Uuid
  sortOrder                          Int
  isActive                           Boolean                                      @default(true)
  createdAt                          DateTime                                     @default(now()) @db.Timestamptz(3)
  version                            ProviderTaxonomyVersion                      @relation(fields: [versionId], references: [id], onDelete: Restrict)
  parent                             ProviderTaxonomyTerm?                        @relation("ProviderTaxonomyHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children                           ProviderTaxonomyTerm[]                       @relation("ProviderTaxonomyHierarchy")
  specialismMap                      ProviderSpecialismTaxonomyMap?
  sectorMap                          ProviderSectorTaxonomyMap?
  certificationMap                   ProviderCertificationTaxonomyMap?
  capabilityServices                 ProviderCapabilityRevision[]                 @relation("CapabilityService")
  capabilitySpecialisms              ProviderCapabilityRevision[]                 @relation("CapabilitySpecialism")
  capabilityCompetencies             ProviderCapabilityRevision[]                 @relation("CapabilityCompetency")
  sectorExperienceRevisions          ProviderSectorExperienceRevision[]
  workAreaRevisions                  ProviderWorkAreaRevision[]
  professionalQualificationRevisions ProviderProfessionalQualificationRevision[]
  organizationQualificationRevisions ProviderOrganizationQualificationRevision[]
  insuranceTypeRevisions             ProviderInsuranceRevision[]
  requirementServices                ProviderCapabilityQualificationRequirement[] @relation("RequirementService")
  requirementSpecialisms             ProviderCapabilityQualificationRequirement[] @relation("RequirementSpecialism")
  requirementTerms                   ProviderCapabilityQualificationRequirement[] @relation("RequirementTerm")
  insuranceRequirementTypes          ProviderInsuranceRequirement[]

  @@unique([versionId, code])
  @@unique([versionId, sortOrder])
  @@index([parentId])
}

model ProviderSpecialismTaxonomyMap {
  termId       String               @id @db.Uuid
  specialismId String               @unique @db.Uuid
  term         ProviderTaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Restrict)
  specialism   Specialism           @relation(fields: [specialismId], references: [id], onDelete: Restrict)
}

model ProviderSectorTaxonomyMap {
  termId   String               @id @db.Uuid
  sectorId String               @unique @db.Uuid
  term     ProviderTaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Restrict)
  sector   Sector               @relation(fields: [sectorId], references: [id], onDelete: Restrict)
}

model ProviderCertificationTaxonomyMap {
  termId          String               @id @db.Uuid
  certificationId String               @unique @db.Uuid
  term            ProviderTaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Restrict)
  certification   Certification        @relation(fields: [certificationId], references: [id], onDelete: Restrict)
}

model ProviderPlatformPermissionGrant {
  id              String                                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                                @db.Uuid
  permission      ProviderPlatformPermission
  validFrom       DateTime                              @db.Timestamptz(3)
  validUntil      DateTime?                             @db.Timestamptz(3)
  grantedByUserId String                                @db.Uuid
  reasonCode      String
  createdAt       DateTime                              @default(now()) @db.Timestamptz(3)
  user            User                                  @relation("ProviderPermissionSubject", fields: [userId], references: [id], onDelete: Restrict)
  grantedByUser   User                                  @relation("ProviderPermissionGranter", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revocation      ProviderPlatformPermissionRevocation?

  @@index([userId, permission, validFrom, validUntil])
}

model ProviderPlatformPermissionRevocation {
  id              String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grantId         String                          @unique @db.Uuid
  revokedByUserId String                          @db.Uuid
  reasonCode      String
  revokedAt       DateTime                        @default(now()) @db.Timestamptz(3)
  grant           ProviderPlatformPermissionGrant @relation(fields: [grantId], references: [id], onDelete: Restrict)
  revokedByUser   User                            @relation("ProviderPermissionRevoker", fields: [revokedByUserId], references: [id], onDelete: Restrict)
}

model ProviderCapability {
  id                         String                                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerProfileId          String                                        @db.Uuid
  version                    Int                                           @default(1)
  status                     ProviderRecordStatus                          @default(ACTIVE)
  legacySourceId             String?                                       @unique @db.Uuid
  createdAt                  DateTime                                      @default(now()) @db.Timestamptz(3)
  providerProfile            ProviderProfile                               @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  revisions                  ProviderCapabilityRevision[]
  professionalQualifications ProviderProfessionalQualificationCapability[]
  qualificationDecisions     ProviderQualificationDecision[]

  @@index([providerProfileId, status])
}

model ProviderCapabilityRevision {
  id                   String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerCapabilityId String                       @db.Uuid
  version              Int
  serviceTermId        String?                      @db.Uuid
  specialismTermId     String?                      @db.Uuid
  competencyTermId     String?                      @db.Uuid
  deliveryModes        ProviderDeliveryMode[]
  verificationLevel    ProviderVerificationLevel    @default(SELF_DECLARED)
  validFrom            DateTime?                    @db.Timestamptz(3)
